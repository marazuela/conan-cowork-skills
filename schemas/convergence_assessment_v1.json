{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://conan/marazuela/schemas/convergence_assessment_v1.json",
  "title": "Convergence Assessment (Stage 10 Output, v1)",
  "description": "Strict schema for the convergence_assessments row produced by the v3 orchestrator. Mirrors the table columns from migration 20260506000020_v3_phase_2_orchestrator_schema.sql.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "asset_id",
    "conviction_pct_calibrated",
    "evidence_quality",
    "band",
    "cited_prose_blocks",
    "constitutional_pass",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "asset_id": { "type": "string", "format": "uuid" },
    "rubric_version": { "type": ["string", "null"] },
    "orchestrator_version": { "type": "string" },

    "conviction_pct_raw": { "type": "number", "minimum": 0, "maximum": 100 },
    "conviction_pct_calibrated": { "type": "number", "minimum": 0, "maximum": 100 },
    "evidence_quality": { "type": "number", "minimum": 0, "maximum": 1 },
    "band": { "type": "string", "enum": ["immediate", "watchlist", "archive", "discard"] },

    "cited_prose_blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section", "text"],
        "properties": {
          "section": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "fact_citations": { "type": "array", "items": { "type": "string" } },
          "doc_citations": { "type": "array", "items": { "type": "string" } },
          "native_citations": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "Anthropic Citations API metadata block — passed through from response.",
              "additionalProperties": true
            }
          }
        }
      }
    },

    "key_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "fact_id"],
        "properties": {
          "text": { "type": "string" },
          "fact_id": { "type": "string", "format": "uuid" }
        }
      }
    },

    "uncertainties": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question"],
        "properties": {
          "question": { "type": "string" },
          "why_matters": { "type": ["string", "null"] },
          "how_to_resolve": { "type": ["string", "null"] }
        }
      }
    },

    "hypotheses": { "type": "array" },
    "pre_mortem": { "type": "object" },
    "reference_class": { "type": ["string", "null"] },
    "reference_class_base_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "similar_resolved_case_ids": { "type": "array", "items": { "type": "string" } },

    "ensemble_n": { "type": ["integer", "null"], "minimum": 1 },
    "ensemble_mean": { "type": ["number", "null"] },
    "ensemble_dispersion": { "type": ["number", "null"] },

    "constitutional_pass": { "type": "boolean" },
    "constitutional_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },

    "sub_agent_call_ids": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "description": "FK to sub_agent_calls.id rows produced by Stream 4 dispatcher."
    },

    "reasoning_summary": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
