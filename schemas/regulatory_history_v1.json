{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://conan/marazuela/schemas/regulatory_history_v1.json",
  "title": "Regulatory History Sub-Agent Output (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "asset_id",
    "prior_adcomms",
    "analogous_approvals",
    "regulatory_risks",
    "retrieved_at"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "asset_id": { "type": "string", "format": "uuid" },
    "prior_adcomms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "drug", "indication", "vote"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "drug": { "type": "string", "minLength": 1 },
          "sponsor": { "type": ["string", "null"] },
          "indication": { "type": "string", "minLength": 1 },
          "vote": {
            "type": "string",
            "description": "e.g. '14-1 favor', '6-9 against', 'split', 'no vote — discussion only'"
          },
          "fda_concerns": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "maxItems": 15
          },
          "primary_source_url": { "type": "string", "format": "uri" },
          "fact_citations": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "analogous_approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["drug", "indication", "approval_date", "basis_for_approval"],
        "properties": {
          "drug": { "type": "string" },
          "indication": { "type": "string" },
          "approval_date": { "type": "string", "format": "date" },
          "basis_for_approval": { "type": "string" },
          "endpoint_used": { "type": ["string", "null"] },
          "primary_source_url": { "type": "string", "format": "uri" },
          "fact_citations": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "regulatory_risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk", "severity"],
        "properties": {
          "risk": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "mitigation": { "type": ["string", "null"] }
        }
      }
    },
    "crl_precedent_found": { "type": "boolean", "default": false },
    "retrieved_at": { "type": "string", "format": "date-time" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "partial_output": { "type": "boolean", "default": false }
  }
}
